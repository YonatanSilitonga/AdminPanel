APP_NAME="Smart Tourism Admin Panel"
APP_ENV=production
APP_KEY=base64:zm0de1bPSHuCovWuuk9ddxWRrOYqY0yW0YQ2sXgBp9c=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ============================================
# DATABASE - MongoDB Atlas (Cloud) atau Self-hosted
# ============================================
DB_CONNECTION=mongodb

# MongoDB Atlas (recommended untuk hosting):
# Format: mongodb+srv://username:password@cluster.mongodb.net
MONGODB_DSN=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net
MONGODB_DATABASE=smarttourism

# ============================================
# SESSION & CACHE
# ============================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ============================================
# CLOUDINARY - Penyimpanan Gambar
# Daftar gratis: https://cloudinary.com → Dashboard → API Keys
# ============================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ============================================
# SENTIMENT ANALYSIS API - Python (PythonAnywhere)
# Deploy Flask API ke: https://www.pythonanywhere.com
# URL format: https://username.pythonanywhere.com
# ============================================
SENTIMENT_SERVICE_ENABLED=true
SENTIMENT_API_URL=https://your-username.pythonanywhere.com
SENTIMENT_API_TIMEOUT=30
SENTIMENT_AUTO_SAVE=true

# ============================================
# MAIL (opsional - untuk notifikasi)
# ============================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="admin@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# REDIS (opsional)
# ============================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
